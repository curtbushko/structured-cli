{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/ruff.json",
  "title": "Ruff Check Output",
  "type": "object",
  "description": "Compact output format for Ruff linter optimized for token efficiency",
  "properties": {
    "total_issues": {
      "type": "integer",
      "description": "Total count of all lint issues"
    },
    "files_with_issues": {
      "type": "integer",
      "description": "Count of files with at least one issue"
    },
    "severity_counts": {
      "type": "object",
      "description": "Map of severity levels to their counts",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "results": {
      "type": "array",
      "description": "Issues grouped by file in compact tuple format: [filename, issue_count, issues]",
      "items": {
        "type": "array",
        "description": "File group: [filename, issue_count, issues]",
        "minItems": 3,
        "maxItems": 3,
        "items": [
          {
            "type": "string",
            "description": "File path"
          },
          {
            "type": "integer",
            "description": "Number of issues in this file"
          },
          {
            "type": "array",
            "description": "Issues as tuples: [line, severity, message, rule_code]",
            "items": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": [
                {
                  "type": "integer",
                  "description": "Line number"
                },
                {
                  "type": "string",
                  "description": "Severity (error, warning, info)"
                },
                {
                  "type": "string",
                  "description": "Issue message"
                },
                {
                  "type": "string",
                  "description": "Ruff rule code (e.g., E501, F401, I001)"
                }
              ]
            }
          }
        ]
      }
    },
    "truncated": {
      "type": "integer",
      "description": "Count of issues omitted due to truncation limits"
    }
  },
  "required": ["total_issues", "files_with_issues", "severity_counts", "results", "truncated"],
  "examples": [
    {
      "total_issues": 4,
      "files_with_issues": 2,
      "severity_counts": {
        "error": 2,
        "warning": 2
      },
      "results": [
        ["src/main.py", 2, [
          [15, "error", "Line too long (120 > 88 characters)", "E501"],
          [22, "warning", "'os' imported but unused", "F401"]
        ]],
        ["src/utils.py", 2, [
          [8, "warning", "Missing docstring in public function", "D103"],
          [12, "error", "Undefined name 'foo'", "F821"]
        ]]
      ],
      "truncated": 0
    }
  ]
}
