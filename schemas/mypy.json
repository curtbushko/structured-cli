{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/mypy.json",
  "title": "Mypy Type Check Output",
  "type": "object",
  "properties": {
    "total_issues": {
      "type": "integer",
      "description": "Total count of all type errors"
    },
    "files_with_issues": {
      "type": "integer",
      "description": "Count of files with at least one error"
    },
    "severity_counts": {
      "type": "object",
      "description": "Map of severity levels to their counts",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "results": {
      "type": "array",
      "description": "Errors grouped by file in compact tuple format [filename, count, issues]",
      "items": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": [
          {
            "type": "string",
            "description": "File path"
          },
          {
            "type": "integer",
            "description": "Number of issues in this file"
          },
          {
            "type": "array",
            "description": "Issues as tuples [line, severity, message, error_code]",
            "items": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": [
                {
                  "type": "integer",
                  "description": "Line number"
                },
                {
                  "type": "string",
                  "enum": ["error", "warning", "info"],
                  "description": "Severity level (error, warning, note mapped to info)"
                },
                {
                  "type": "string",
                  "description": "Error message (truncated to 100 chars max)"
                },
                {
                  "type": "string",
                  "description": "Error code (e.g., arg-type, return-value)"
                }
              ]
            }
          }
        ]
      }
    },
    "truncated": {
      "type": "integer",
      "description": "Count of errors omitted due to truncation limits"
    },
    "summary": {
      "type": "string",
      "description": "Summary line from mypy output"
    }
  },
  "required": ["total_issues", "files_with_issues", "severity_counts", "results", "truncated", "summary"],
  "examples": [
    {
      "total_issues": 3,
      "files_with_issues": 2,
      "severity_counts": {
        "error": 2,
        "warning": 1
      },
      "results": [
        ["src/main.py", 2, [
          [10, "error", "Argument 1 to \"process\" has incompatible type \"str\"; expected \"int\"", "arg-type"],
          [25, "error", "Incompatible return value type (got \"None\", expected \"str\")", "return-value"]
        ]],
        ["src/utils.py", 1, [
          [15, "warning", "Name \"x\" already defined on line 10", "name-defined"]
        ]]
      ],
      "truncated": 0,
      "summary": "Found 3 errors in 2 files (checked 5 source files)"
    }
  ]
}
