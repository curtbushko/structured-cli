{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/eslint.json",
  "title": "ESLint Output",
  "type": "object",
  "description": "Compact output format for ESLint optimized for token efficiency. Issues are grouped by file and represented as tuples to minimize JSON overhead.",
  "properties": {
    "total_issues": {
      "type": "integer",
      "description": "Total count of all lint issues"
    },
    "files_with_issues": {
      "type": "integer",
      "description": "Count of files with at least one issue"
    },
    "severity_counts": {
      "type": "object",
      "description": "Map of severity levels to their counts",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "results": {
      "type": "array",
      "description": "Issues grouped by file in compact tuple format: [filename, issue_count, issues]",
      "items": {
        "type": "array",
        "description": "File group: [filename, issue_count, issues]",
        "minItems": 3,
        "maxItems": 3,
        "items": [
          {
            "type": "string",
            "description": "File path"
          },
          {
            "type": "integer",
            "description": "Number of issues in this file"
          },
          {
            "type": "array",
            "description": "Issues as tuples: [line, severity, message, rule]",
            "items": {
              "type": "array",
              "description": "Issue tuple: [line, severity, message, rule]",
              "minItems": 4,
              "maxItems": 4,
              "items": [
                {
                  "type": "integer",
                  "description": "Line number"
                },
                {
                  "type": "string",
                  "description": "Severity (error, warning)"
                },
                {
                  "type": "string",
                  "description": "Issue message"
                },
                {
                  "type": "string",
                  "description": "ESLint rule that was violated"
                }
              ]
            }
          }
        ]
      }
    },
    "truncated": {
      "type": "integer",
      "description": "Count of issues omitted due to truncation limits"
    }
  },
  "required": ["total_issues", "files_with_issues", "severity_counts", "results", "truncated"],
  "examples": [
    {
      "total_issues": 3,
      "files_with_issues": 2,
      "severity_counts": {
        "error": 2,
        "warning": 1
      },
      "results": [
        ["src/index.js", 2, [
          [10, "error", "Unexpected var, use let or const instead", "no-var"],
          [15, "warning", "Missing semicolon", "semi"]
        ]],
        ["src/utils.js", 1, [
          [5, "error", "'foo' is defined but never used", "no-unused-vars"]
        ]]
      ],
      "truncated": 0
    }
  ]
}
