{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/df.json",
  "title": "DF Output",
  "type": "object",
  "properties": {
    "filesystems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filesystem": { "type": "string" },
          "type": { "type": "string" },
          "size": { "type": "integer" },
          "used": { "type": "integer" },
          "available": { "type": "integer" },
          "usePercent": { "type": "number" },
          "mountedOn": { "type": "string" },
          "sizeHuman": { "type": "string" },
          "usedHuman": { "type": "string" },
          "availableHuman": { "type": "string" }
        },
        "required": ["filesystem", "size", "used", "available", "usePercent", "mountedOn"]
      }
    }
  },
  "required": ["filesystems"]
}
