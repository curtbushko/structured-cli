{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/golangci-lint.json",
  "title": "golangci-lint Output",
  "type": "object",
  "description": "Compact output format for golangci-lint optimized for token efficiency. Issues are grouped by file and represented as tuples to minimize JSON overhead.",
  "properties": {
    "total_issues": {
      "type": "integer",
      "description": "Total count of all lint issues"
    },
    "files_with_issues": {
      "type": "integer",
      "description": "Count of files with at least one issue"
    },
    "severity_counts": {
      "type": "object",
      "description": "Map of severity levels to their counts",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "results": {
      "type": "array",
      "description": "Issues grouped by file in compact tuple format: [filename, issue_count, issues]",
      "items": {
        "type": "array",
        "description": "File group: [filename, issue_count, issues]",
        "minItems": 3,
        "maxItems": 3,
        "items": [
          {
            "type": "string",
            "description": "File path"
          },
          {
            "type": "integer",
            "description": "Number of issues in this file"
          },
          {
            "type": "array",
            "description": "Issues as tuples: [line, severity, message, linter]",
            "items": {
              "type": "array",
              "description": "Issue tuple: [line, severity, message, linter]",
              "minItems": 4,
              "maxItems": 4,
              "items": [
                {
                  "type": "integer",
                  "description": "Line number"
                },
                {
                  "type": "string",
                  "description": "Severity (error, warning)"
                },
                {
                  "type": "string",
                  "description": "Issue message"
                },
                {
                  "type": "string",
                  "description": "Linter that found the issue (e.g., errcheck, govet)"
                }
              ]
            }
          }
        ]
      }
    },
    "truncated": {
      "type": "integer",
      "description": "Count of issues omitted due to truncation limits"
    }
  },
  "required": ["total_issues", "files_with_issues", "severity_counts", "results", "truncated"],
  "examples": [
    {
      "total_issues": 3,
      "files_with_issues": 2,
      "severity_counts": {
        "error": 3
      },
      "results": [
        ["main.go", 2, [
          [15, "error", "Error return value not checked", "errcheck"],
          [22, "error", "ineffectual assignment to err", "ineffassign"]
        ]],
        ["pkg/handler.go", 1, [
          [10, "error", "unused parameter: ctx", "unparam"]
        ]]
      ],
      "truncated": 0
    }
  ]
}
