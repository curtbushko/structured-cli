{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/tail.json",
  "title": "Tail Output",
  "type": "object",
  "properties": {
    "content": { "type": "string" },
    "lines": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lineCount": { "type": "integer" }
  },
  "required": ["content", "lines", "lineCount"]
}
