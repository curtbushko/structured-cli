{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/cargo-clippy.json",
  "title": "Cargo Clippy Output",
  "description": "Compact format output for cargo clippy lint results",
  "type": "object",
  "properties": {
    "total_issues": {
      "type": "integer",
      "description": "Total count of all lint issues"
    },
    "files_with_issues": {
      "type": "integer",
      "description": "Count of files with at least one issue"
    },
    "severity_counts": {
      "type": "object",
      "description": "Maps severity levels to their counts",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "results": {
      "type": "array",
      "description": "Grouped issues by file in compact tuple format",
      "items": {
        "type": "array",
        "description": "FileIssueGroup: [filename, issue_count, issues]",
        "items": [
          {
            "type": "string",
            "description": "File path"
          },
          {
            "type": "integer",
            "description": "Number of issues in file"
          },
          {
            "type": "array",
            "description": "Array of issue tuples",
            "items": {
              "type": "array",
              "description": "IssueTuple: [line, severity, message, rule_id]",
              "items": [
                {
                  "type": "integer",
                  "description": "Line number"
                },
                {
                  "type": "string",
                  "description": "Severity level (error, warning, info, style)"
                },
                {
                  "type": "string",
                  "description": "Issue message"
                },
                {
                  "type": "string",
                  "description": "Lint rule ID (e.g., clippy::unwrap_used)"
                }
              ]
            }
          }
        ]
      }
    },
    "truncated": {
      "type": "integer",
      "description": "Number of issues omitted due to truncation limits"
    }
  },
  "required": ["total_issues", "files_with_issues", "severity_counts", "results", "truncated"],
  "examples": [
    {
      "total_issues": 3,
      "files_with_issues": 2,
      "severity_counts": {
        "warning": 2,
        "error": 1
      },
      "results": [
        ["src/main.rs", 2, [
          [15, "warning", "use of `unwrap()` on a `Result` value", "clippy::unwrap_used"],
          [22, "warning", "variable does not need to be mutable", "clippy::needless_mut"]
        ]],
        ["src/lib.rs", 1, [
          [10, "error", "borrow of moved value: `x`", "E0382"]
        ]]
      ],
      "truncated": 0
    }
  ]
}
