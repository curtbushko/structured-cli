{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structured-cli.dev/schemas/helm-list.json",
  "title": "Helm List Output",
  "type": "object",
  "properties": {
    "releases": {
      "type": "array",
      "description": "List of Helm releases",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Release name" },
          "namespace": { "type": "string", "description": "Kubernetes namespace where the release is installed" },
          "revision": { "type": "integer", "description": "Release revision number" },
          "updated": { "type": "string", "description": "Timestamp of the last update" },
          "status": {
            "type": "string",
            "description": "Release status (e.g., deployed, failed, pending-install, pending-upgrade, uninstalling)"
          },
          "chart": { "type": "string", "description": "Chart name and version (e.g., nginx-1.0.0)" },
          "app_version": { "type": "string", "description": "Application version from the chart" }
        },
        "required": ["name", "status", "chart"]
      }
    }
  },
  "required": ["releases"]
}
